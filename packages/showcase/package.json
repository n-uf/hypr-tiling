{
  "name": "hypr-tiling-showcase",
  "version": "26.6.1",
  "private": false,
  "description": "Interactive React showcase for hypr-tiling layouts, commands, keyboard flows, and runtime pane orchestration.",
  "keywords": [
    "react",
    "tiling",
    "showcase",
    "interactive-demo",
    "resizable-panes",
    "window-manager-ui",
    "layout-engine",
    "hyprland"
  ],
  "license": "LicenseRef-PolyForm-Perimeter-1.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n-uf/hypr-tiling.git"
  },
  "homepage": "https://hypr-tiling.n-uf.com/showcase",
  "bugs": {
    "url": "https://github.com/n-uf/hypr-tiling/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react --external react-dom --external @n-uf/hypr-tiling --external @n-uf/hypr-tiling/devtools",
    "typecheck": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "@n-uf/hypr-tiling": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
