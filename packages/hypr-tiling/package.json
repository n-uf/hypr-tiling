{
  "name": "@n-uf/hypr-tiling",
  "version": "26.6.2",
  "private": false,
  "description": "Recursive split-tree tiling renderer for React.",
  "license": "PolyForm-Perimeter-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n-uf/hypr-tiling.git"
  },
  "homepage": "https://github.com/n-uf/hypr-tiling#readme",
  "bugs": {
    "url": "https://github.com/n-uf/hypr-tiling/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --dts --clean --external react --external react-dom",
    "check": "pnpm typecheck && pnpm test",
    "prepublishOnly": "pnpm build",
    "release": "if [ \"$npm_config_nobump\" = \"true\" ]; then npm publish --access public; else node ./scripts/calendar-version-bump.mjs --apply && npm publish --access public; fi",
    "typecheck": "tsc --project tsconfig.json",
    "test": "jest",
    "release:next-version": "node ./scripts/calendar-version-bump.mjs --dry-run"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-jest": "^29.4.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
