{
  "name": "hypr-tiling-workspace",
  "version": "26.6.1",
  "private": true,
  "description": "Workspace for hypr-tiling packages and homepage app.",
  "license": "LicenseRef-PolyForm-Perimeter-1.0.1",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --filter hypr-tiling-web dev",
    "build": "pnpm -r --filter './packages/*' build && pnpm --filter hypr-tiling-web build",
    "typecheck": "pnpm -r --filter './packages/*' typecheck && pnpm --filter hypr-tiling-web typecheck",
    "test": "pnpm --filter @n-uf/hypr-tiling test",
    "check": "pnpm typecheck && pnpm test",
    "release": "pnpm --filter @n-uf/hypr-tiling release"
  }
}
